# ── Backend / API ─────────────────────────────────────────────────────────────

# SQLAlchemy database URL.
# Local dev default: SQLite at data/tcf.db (leave blank to use default).
# Docker Compose: postgresql+psycopg://tcf:tcf@postgres:5432/tcf
DATABASE_URL=

# Absolute path to the folder containing source PDFs and MP3s.
# Defaults to ./Sources relative to the project root.
SOURCE_ROOT=

# Absolute path where the catalog builder writes catalog.sqlite and reports.
# Defaults to ./content/generated relative to the project root.
GENERATED_ROOT=

# OpenAI API key — only required for Whisper transcription (npm run transcribe-catalog).
# Leave blank if you are not running the transcription step.
OPENAI_API_KEY=

# ── Frontend / Next.js ────────────────────────────────────────────────────────

# URL of the running FastAPI backend.
# Local dev: http://localhost:8000
# Leave blank when building the fully-static GitHub Pages export.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL for hashed audio files served from a GitHub Release.
# Format: https://github.com/OWNER/REPO/releases/download/audio-v1
# Leave blank for local dev — audio is then served by FastAPI at /api/catalog/audio/.
# See README.md "Audio hosting" section for the full setup workflow.
NEXT_PUBLIC_AUDIO_BASE_URL=

# Sub-path for GitHub Pages deployment, e.g. /JessicasFrench
# Leave blank when the site is served from a custom domain or root URL.
NEXT_PUBLIC_BASE_PATH=
