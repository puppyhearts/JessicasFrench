# ── Local Docker / FastAPI dev ───────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://tcf:tcf@postgres:5432/tcf
NEXT_PUBLIC_API_URL=http://localhost:8000
SOURCE_ROOT=/app/Sources
GENERATED_ROOT=/app/content/generated

# ── Transcription (optional, leave blank to skip) ────────────────────────────
OPENAI_API_KEY=
WHISPER_MODEL=large-v3

# ── Static / GitHub Pages audio hosting ─────────────────────────────────────
# Set this to the base URL where audio files are hosted (no trailing slash).
# Audio files must be named {sha256}.mp3 — use scripts/prepare-audio-release.py
# to copy them into the correct layout, then upload to a GitHub Release.
# Example: https://github.com/OWNER/REPO/releases/download/audio-v1
# Leave blank during local development (falls back to FastAPI audio routes).
NEXT_PUBLIC_AUDIO_BASE_URL=

